-- Horizontal Rectangular Menu
local menuFrame = Instance.new("Frame")
menuFrame.Size = UDim2.new(0, 620, 0, 180)  -- Horizontal layout
menuFrame.Position = UDim2.new(0.3, 0, 0.4, 0)
menuFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 25)
menuFrame.Visible = false
menuFrame.Parent = screenGui

local menuCorner = Instance.new("UICorner")
menuCorner.CornerRadius = UDim.new(0, 12)
menuCorner.Parent = menuFrame

-- Draggable
local isDragging = false
local dragStartPos
menuFrame.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        dragStartPos = inp.Position
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if isDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = inp.Position - dragStartPos
        menuFrame.Position = UDim2.new(menuFrame.Position.X.Scale, menuFrame.Position.X.Offset + delta.X, menuFrame.Position.Y.Scale, menuFrame.Position.Y.Offset + delta.Y)
    end
end)
menuFrame.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)

-- Close Button X
local closeX = Instance.new("TextButton")
