-- Sheriff Detection
local function updateRole()
    isSheriff = false
    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("gun") or tool.Name == "Sheriff") then
            isSheriff = true
        end
    end
end

-- Noclip Handler
local noclipConn
RunService.Stepped:Connect(function()
    if isNoclipEnabled and character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Autoaim for Sheriff (headshot correction on shot)
mouse.Button1Down:Connect(function()
    updateRole()
    if isAutoAimEnabled and isSheriff then
        local target = mouse.Target
        if target and target.Parent:FindFirstChild("Humanoid") then
            local humRoot = target.Parent:FindFirstChild("HumanoidRootPart")
            if humRoot then
                -- Silent aim correction to head
                local head = target.Parent:FindFirstChild("Head")
                if head then
                    mouse.Target = head
                    -- Additional projectile adjustment simulation
                end
            end
        end
    end
end)

RunService.Heartbeat:Connect(updateRole)

print("[IRONCLAD] BigernHub MM2 Script Loaded - Sheriff Autoaim & Noclip Active")
