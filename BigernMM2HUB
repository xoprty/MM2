-- Функция создания переключателя (Toggle)
local function createToggle(parent, yPos, labelText, onToggle)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -10, 0, 35)
    toggleFrame.Position = UDim2.new(0, 5, 0, yPos)
    toggleFrame.BackgroundTransparency = 1
    toggleFrame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextSize = 18
    label.Font = Enum.Font.SourceSansBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame

    local toggleButton = Instance.new("TextButton")
    toggleButton.Size = UDim2.new(0, 70, 1, 0)
    toggleButton.Position = UDim2.new(1, -75, 0, 0)
    toggleButton.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
    toggleButton.Text = "OFF"
    toggleButton.TextColor3 = Color3.new(1, 1, 1)
    toggleButton.TextSize = 16
    toggleButton.Font = Enum.Font.SourceSansBold
    toggleButton.BorderSizePixel = 0
    toggleButton.Parent = toggleFrame

    local state = false
    toggleButton.MouseButton1Click:Connect(function()
        state = not state
        toggleButton.Text = state and "ON" or "OFF"
        toggleButton.BackgroundColor3 = state and Color3.new(0, 0.6, 0) or Color3.new(0.2, 0.2, 0.2)
        if onToggle then onToggle(state) end
    end)
    return toggleButton
end

-- === Toggle для Autoaim ===
createToggle(functionsFrame, 5, "Autoaim", function(enabled)
    autoaimEnabled = enabled
    if enabled then
        -- Запускаем цикл автоаима
        if autoaimLoop then return end
        autoaimLoop = game:GetService("RunService").Heartbeat:Connect(function()
            if not autoaimEnabled then
                if autoaimLoop then autoaimLoop:Disconnect(); autoaimLoop = nil end
                return
            end
            -- Проверяем, является ли игрок Sheriff
            local character = player.Character
            if not character or not character.Parent then return end
            -- Проверяем роль (упрощённо: ищем инструмент "Gun" или по тегам, но сделаем по имени)
            -- В MM2 роли хранятся в Remote или значении, но для примера проверим наличие оружия Sheriff
            -- У Sheriff есть пистолет, у Murderer - нож. Можно проверить, есть ли у игрока инструмент "Gun"
            local hasGun = false
            for _, tool in pairs(character:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("gun") then
                    hasGun = true
                    break
                end
            end
            if not hasGun then return end -- не Sheriff

            -- Ищем Murderer'а
            local murderer = nil
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character.Parent then
                    -- Проверяем, есть ли у него нож (или просто берём любого)
                    -- В реальности нужно определять роль, но упростим: берём первого игрока с инструментом "Knife"
                    local hasKnife = false
                    for _, tool in pairs(p.Character:GetChildren()) do
                        if tool:IsA("Tool") and tool.Name:lower():find("knife") then
                            hasKnife = true
                            break
                        end
                    end
                    if hasKnife then
                        murderer = p.Character
                        break
                    end
                end
            end
            if murderer then
                local head = murderer:FindFirstChild("Head") or murderer:FindFirstChild("HumanoidRootPart")
                if head then
                    mouse.Target = head
                end
            end
        end)
    else
        -- Останавливаем цикл
        if autoaimLoop then
            autoaimLoop:Disconnect()
            autoaimLoop = nil
        end
        mouse.Target = nil
    end
end)

-- === Toggle для Noclip ===
createToggle(functionsFrame, 45, "Noclip", function(enabled)
    noclipEnabled = enabled
    local function setCollision(state)
        local char = player.Character
        if not char then return end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = state
            end
        end
    end

    if enabled then
        -- Включаем noclip
        setCollision(false)
        -- Добавляем обработчик для новых частей (например, при пересоздании персонажа)
        local function onCharacterAdded(newChar)
            newChar:WaitForChild("HumanoidRootPart")
            setCollision(false)
        end
        if player.Character then
            onCharacterAdded(player.Character)
        end
        -- Сохраняем соединение
        local conn = player.CharacterAdded:Connect(onCharacterAdded)
        table.insert(noclipConnections, conn)
    else
        -- Отключаем noclip
        setCollision(true)
        -- Удаляем обработчики
        for _, conn in ipairs(noclipConnections) do
            conn:Disconnect()
        end
        noclipConnections = {}
    end
end)

